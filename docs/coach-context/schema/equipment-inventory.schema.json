{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enqidu.local/schemas/coach-context/equipment-inventory.schema.json",
  "title": "ENQIDU Equipment Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["locations"],
  "properties": {
    "schema_version": {
      "type": "string",
      "default": "1.0.0"
    },
    "source_id": {
      "type": ["string", "null"]
    },
    "role": {
      "type": ["string", "null"],
      "examples": ["home_equipment_inventory", "gym_equipment_inventory", "travel_equipment_inventory"]
    },
    "applies_when": {
      "type": ["object", "null"],
      "additionalProperties": {
        "type": ["string", "number", "boolean", "null"]
      }
    },
    "must_not_apply_when": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "locations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/location"
      }
    },
    "notes": {
      "type": ["string", "null"]
    }
  },
  "$defs": {
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "equipment"],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "location_type": {
          "type": ["string", "null"],
          "enum": ["home", "outside_home", "gym", "studio", "outdoor", "unknown", "travel", null]
        },
        "equipment": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/equipment_item"
          }
        }
      }
    },
    "equipment_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "category": {
          "type": ["string", "null"],
          "examples": ["barbell", "dumbbell", "machine", "cardio", "calisthenics", "mobility"]
        },
        "quantity": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "load_range": {
          "type": ["string", "null"]
        },
        "availability": {
          "type": ["string", "null"],
          "examples": ["always", "sometimes", "unknown"]
        },
        "notes": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
