{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enqidu.local/schemas/coach-context/injury-constraints.schema.json",
  "title": "ENQIDU Injury Constraints",
  "type": "object",
  "additionalProperties": false,
  "required": ["constraints"],
  "properties": {
    "schema_version": {
      "type": "string",
      "default": "1.0.0"
    },
    "constraints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/constraint"
      }
    },
    "global_risk_policy": {
      "type": ["string", "null"],
      "examples": ["stop_on_sharp_pain", "reduce_load_on_pain_increase", "medical_clearance_required"]
    }
  },
  "$defs": {
    "constraint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["region", "status"],
      "properties": {
        "region": {
          "type": "string",
          "examples": ["lumbar", "knee", "shoulder", "ankle", "general"]
        },
        "status": {
          "type": "string",
          "enum": ["active", "monitor", "resolved", "unknown"]
        },
        "severity": {
          "type": ["string", "null"],
          "enum": ["low", "medium", "high", null]
        },
        "pain_scale_limit": {
          "type": ["integer", "null"],
          "minimum": 0,
          "maximum": 10
        },
        "avoid": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "prefer": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "monitoring_questions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updated_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "notes": {
          "type": ["string", "null"]
        }
      }
    }
  }
}

